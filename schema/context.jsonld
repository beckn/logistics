{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.org/core/",
    "log": "https://schema.beckn.org/logistics/",

    "Shipment": "log:Shipment",
    "Package": "log:Package",
    "Courier": "log:Courier",
    "Carrier": "log:Carrier",
    "Consignment": "log:Consignment",
    "Driver": "log:Driver",
    "Vehicle": "log:Vehicle",
    "Route": "log:Route",
    "Waypoint": "log:Waypoint",
    "Hub": "log:Hub",
    "TrackingUpdate": "log:TrackingUpdate",
    "DeliverySlot": "log:DeliverySlot",
    "Proof": "log:Proof",
    "Place": "log:Place",
    "Alert": "log:Alert",
    "CancellationPolicy": "log:CancellationPolicy",
    "ReturnPolicy": "log:ReturnPolicy",
    "Fare": "log:Fare",
    "FareBreakup": "log:FareBreakup",
    "Rating": "log:Rating",
    "Feedback": "log:Feedback",
    "SupportCase": "log:SupportCase",
    "Operator": "log:Operator",
    "Contact": "log:Contact",
    "Receipt": "log:Receipt",

    "id": "@id",
    "type": "@type",
    "label": { "@id": "rdfs:label", "@language": "en" },
    "comment": { "@id": "rdfs:comment", "@language": "en" },
    "subClassOf": { "@id": "rdfs:subClassOf", "@type": "@id" },
    "domain": { "@id": "rdfs:domain", "@type": "@id" },
    "range": { "@id": "rdfs:range", "@type": "@id" },
    "equivalentClass": { "@id": "owl:equivalentClass", "@type": "@id" },
    "exactMatch": { "@id": "skos:exactMatch", "@type": "@id" },
    "closeMatch": { "@id": "skos:closeMatch", "@type": "@id" },
    "broadMatch": { "@id": "skos:broadMatch", "@type": "@id" },

    "shipmentId": { "@id": "log:shipmentId", "@type": "xsd:string" },
    "trackingId": { "@id": "log:trackingId", "@type": "xsd:string" },
    "status": { "@id": "log:status", "@type": "xsd:string" },
    "origin": { "@id": "log:origin", "@type": "@id" },
    "destination": { "@id": "log:destination", "@type": "@id" },
    "estimatedDelivery": { "@id": "log:estimatedDelivery", "@type": "xsd:dateTime" },
    "weight": { "@id": "log:weight", "@type": "xsd:decimal" },
    "dimensions": { "@id": "log:dimensions", "@type": "@id" },
    "fragile": { "@id": "log:fragile", "@type": "xsd:boolean" },
    "declaredValue": { "@id": "log:declaredValue", "@type": "xsd:decimal" },
    "waypoints": { "@id": "log:waypoints", "@type": "@id", "@container": "@list" },
    "driverName": { "@id": "log:driverName", "@type": "xsd:string" },
    "vehicleNumber": { "@id": "log:vehicleNumber", "@type": "xsd:string" },
    "proofType": { "@id": "log:proofType", "@type": "xsd:string" },
    "timestamp": { "@id": "log:timestamp", "@type": "xsd:dateTime" },
    "amount": { "@id": "log:amount", "@type": "xsd:decimal" },
    "currency": { "@id": "log:currency", "@type": "xsd:string" }
  }
}
